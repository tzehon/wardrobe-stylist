# Copy to backend/.env (gitignored) and fill in. Only needed to actually call Claude.

# Anthropic API key — held ONLY here, never in the iOS app.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxx

# Shared secret the single iOS client sends as a Bearer token (single-user auth).
# Generate a long random value, e.g.:  python -c "import secrets; print(secrets.token_urlsafe(32))"
DEVICE_TOKEN=replace-with-a-long-random-string

# dev | production
ENVIRONMENT=dev
