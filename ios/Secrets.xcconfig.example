// Copy this file to `Secrets.xcconfig` (which is gitignored) and paste in your two
// values from the Google Cloud OAuth iOS client you created (docs/google-setup.md §4).
//
//   cp ios/Secrets.xcconfig.example ios/Secrets.xcconfig
//   # then edit ios/Secrets.xcconfig
//
// CFBundleURLTypes (Info.plist) reads $(GOOGLE_REVERSED_CLIENT_ID) for the OAuth callback
// URL scheme. GoogleSignIn-iOS reads GIDClientID (= $(GOOGLE_CLIENT_ID)) from Info.plist
// to configure itself at launch.

GOOGLE_CLIENT_ID = 123456789012-abcdefghijklmnopqrstuvwxyz.apps.googleusercontent.com
GOOGLE_REVERSED_CLIENT_ID = com.googleusercontent.apps.123456789012-abcdefghijklmnopqrstuvwxyz
